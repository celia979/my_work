#!/usr/bin/env python3
import sys

def usage():
    print("USAGE")
    print("    ./106bombyx n [k | i0 i1]")
    print("")
    print("DESCRIPTION")
    print("    n       number of first generation individuals")
    print("    k       growth rate from 1 to 4")
    print("    i0      initial generation (included)")
    print("    i1      final generation (included)")

def compute_generations(n, max_gen=100):
    x = [0] * (max_gen + 1)
    x[1] = n
    for i in range(1, max_gen):
        x[i + 1] = x[i] * ((1000 - x[i]) / 1000)
    return x

def mode_single_k(n, k):
    x = float(n)
    print(f"1 {x:.2f}")
    for i in range(1, 100):
        x = k * x * (1000 - x) / 1000
        print(f"{i + 1} {x:.2f}")

def mode_bifurcation(n, i0, i1):
    k = 1.0
    while k <= 4.001:
        x = float(n)
        generations = [x]
        for _ in range(i1):
            x = k * x * (1000 - x) / 1000
            generations.append(x)
        for i in range(i0, i1 + 1):
            print(f"{k:.2f} {generations[i]:.2f}")
        k = round(k + 0.01, 10)

def main():
    args = sys.argv[1:]

    if len(args) == 1 and args[0] == "-h":
        usage()
        sys.exit(0)

    if len(args) == 2:
        try:
            n = float(args[0])
            k = float(args[1])
        except ValueError:
            sys.stderr.write("Error: invalid arguments\n")
            sys.exit(84)
        if k < 1 or k > 4:
            sys.stderr.write("Error: k must be between 1 and 4\n")
            sys.exit(84)
        mode_single_k(n, k)

    elif len(args) == 3:
        try:
            n = float(args[0])
            i0 = int(args[1])
            i1 = int(args[2])
        except ValueError:
            sys.stderr.write("Error: invalid arguments\n")
            sys.exit(84)
        mode_bifurcation(n, i0, i1)

    else:
        sys.stderr.write("Error: invalid number of arguments\n")
        usage()
        sys.exit(84)

if __name__ == "__main__":
    main()
